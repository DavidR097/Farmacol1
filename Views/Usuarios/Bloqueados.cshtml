@model List<Farmacol.Models.UsuarioViewModel>
@{
    ViewData["Title"] = "Usuarios Bloqueados";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <span style="font-size:1.6rem">🔓</span>
    <div>
        <h4 class="mb-0 fw-bold">Usuarios Bloqueados</h4>
        <small class="text-muted">Cuentas bloqueadas por intentos fallidos</small>
    </div>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <div style="font-size:3rem">✅</div>
            <h5 class="mt-3 text-muted">No hay usuarios bloqueados</h5>
            <p class="text-muted small">Todas las cuentas están activas.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Colaborador</th>
                        <th>Usuario</th>
                        <th>Cargo</th>
                        <th>Área</th>
                        <th>Rol</th>
                        <th class="text-center">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@u.Nombre</div>
                                @if (u.Cedula > 0)
                                {
                                    <small class="text-muted">CC @u.Cedula</small>
                                }
                            </td>
                            <td><code>@u.Email</code></td>
                            <td>@u.Cargo</td>
                            <td>
                                @if (!string.IsNullOrEmpty(u.Area))
                                {
                                    <span class="badge bg-secondary">@u.Area</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-primary">@u.Rol</span>
                            </td>
                            <td class="text-center">
                                <form asp-action="Desbloquear" asp-route-id="@u.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-success"
                                            onclick="return confirm('¿Desbloquear a @u.Nombre?')">
                                        🔓 Desbloquear
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <p class="text-muted small mt-2">
        @Model.Count usuario(s) bloqueado(s)
    </p>
}