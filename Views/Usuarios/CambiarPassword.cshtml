@{
    ViewData["Title"] = "Cambiar Contraseña";
}

<h1>Cambiar Contraseña</h1>
<hr />

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<p class="text-muted">Usuario: <strong>@ViewBag.Email</strong></p>

<div class="row">
    <div class="col-md-4">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@ViewBag.UserId" />
            <div class="mb-3">
                <label class="form-label">Nueva Contraseña</label>
                <input type="password" name="nuevaPassword" class="form-control" required minlength="4" />
            </div>
            <button type="submit" class="btn btn-warning">Cambiar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>