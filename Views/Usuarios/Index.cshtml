@model List<Farmacol.Models.UsuarioViewModel>
@{
    ViewData["Title"] = "Usuarios";
    var areas = Model.Where(u => !string.IsNullOrEmpty(u.Area))
                     .Select(u => u.Area!).Distinct().OrderBy(a => a).ToList();
    var roles = Model.Select(u => u.Rol).Distinct().OrderBy(r => r).ToList();
    var bloqueados = Model.Count(u => u.Bloqueado);

    bool esAdmin = User.IsInRole("Administrador");
    bool esTI = User.IsInRole("TI");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">⚙️ Usuarios del Sistema</h2>
        <small class="text-muted">Gestión de accesos y roles</small>
    </div>

    @if (esAdmin)
    {
        <a asp-action="Crear" class="btn btn-primary">➕ Nuevo Usuario</a>
    }
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (bloqueados > 0)
{
    <div class="alert alert-warning d-flex align-items-center gap-2">
        🔒 <strong>@bloqueados usuario(s) bloqueado(s)</strong> por intentos fallidos de contraseña.
        Usa el botón <strong>🔓 Desbloquear</strong> para restaurar el acceso.
    </div>
}

<div class="card border-0 shadow-sm p-3 mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label small text-muted mb-1">Búsqueda</label>
            <input type="text" id="filtroNombre" class="form-control" placeholder="🔍 Nombre, usuario, cargo..." />
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Área</label>
            <select id="filtroArea" class="form-select">
                <option value="">Todas las áreas</option>
                @foreach (var area in areas)
                {
                    <option value="@area.ToLower()">@area</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted mb-1">Rol</label>
            <select id="filtroRol" class="form-select">
                <option value="">Todos los roles</option>
                @foreach (var rol in roles)
                {
                    <option value="@rol.ToLower()">@rol</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted mb-1">Estado</label>
            <select id="filtroEstado" class="form-select">
                <option value="">Todos</option>
                <option value="bloqueado">🔒 Bloqueados</option>
                <option value="activo">✅ Activos</option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="button" class="btn btn-outline-secondary w-100" onclick="limpiarFiltros()">✕</button>
        </div>
    </div>
</div>

<div class="mb-2">
    <small class="text-muted">Mostrando <span id="contadorUsuarios">@Model.Count</span> usuario(s)</small>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="tablaUsuarios">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Cargo / Área</th>
                    <th>Usuario</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var rolColor = item.Rol switch
                    {
                                "Administrador" => "danger",
                                "RRHH" => "success",
                                "Gerente" => "primary",
                                "Directivo" => "dark",
                                "Jefe" => "info",
                                "Coordinador" => "warning",
                                "Asistente" => "secondary",
                        _ => "secondary"
                    };
                    var esBloqueado = item.Bloqueado;

                    <tr data-nombre="@item.Nombre?.ToLower()"
                        data-cargo="@item.Cargo?.ToLower()"
                        data-email="@item.Email?.ToLower()"
                        data-area="@item.Area?.ToLower()"
                        data-rol="@item.Rol?.ToLower()"
                        data-estado="@(esBloqueado ? "bloqueado" : "activo")"
                        class="@(esBloqueado ? "table-danger bg-opacity-25" : "")">

                        <td>
                            <strong>@item.Nombre</strong>
                            @if (esBloqueado)
                            {
                                <span class="badge bg-danger ms-1" title="Bloqueado">🔒</span>
                            }
                        </td>
                        <td>
                            <small class="text-muted">@item.Cargo</small>
                            @if (!string.IsNullOrEmpty(item.Area))
                            {
                                <br />
                                <span class="badge bg-light text-dark border" style="font-size:.7rem">@item.Area</span>
                            }
                        </td>
                        <td><small class="font-monospace text-muted">@item.Email</small></td>
                        <td><span class="badge bg-@rolColor">@item.Rol</span></td>
                        <td>
                            @if (esBloqueado)
                            {
                                <span class="badge bg-danger">🔒 Bloqueado</span>
                            }
                            else
                            {
                                <span class="badge bg-success">✅ Activo</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1 justify-content-center flex-wrap">
                                @if (esBloqueado && (esAdmin || esTI))
                                {
                                    <form asp-action="Desbloquear" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-success"
                                                onclick="return confirm('¿Desbloquear a @item.Nombre?')">
                                            🔓 Desbloquear
                                        </button>
                                    </form>
                                }

                                @if (esAdmin)
                                {
                                    <a asp-action="Editar" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary" title="Editar">✏️</a>
                                    <a asp-action="CambiarPassword" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-warning" title="Cambiar contraseña">🔑</a>
                                    <form asp-action="Eliminar" method="post" class="d-inline"
                                          onsubmit="return confirm('¿Eliminar este usuario?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">🗑️</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        var filtroNombre = document.getElementById('filtroNombre');
        var filtroArea   = document.getElementById('filtroArea');
        var filtroRol    = document.getElementById('filtroRol');
        var filtroEstado = document.getElementById('filtroEstado');
        var contador     = document.getElementById('contadorUsuarios');

        function filtrar() {
            var texto  = (filtroNombre.value || '').toLowerCase();
            var area   = (filtroArea.value   || '').toLowerCase();
            var rol    = (filtroRol.value    || '').toLowerCase();
            var estado = (filtroEstado.value  || '').toLowerCase();
            var filas  = document.querySelectorAll('#tablaUsuarios tbody tr');
            var visible = 0;
            filas.forEach(function (tr) {
                var matchTexto  = !texto  ||
                    (tr.dataset.nombre || '').includes(texto) ||
                    (tr.dataset.cargo  || '').includes(texto) ||
                    (tr.dataset.email  || '').includes(texto);
                var matchArea   = !area   || (tr.dataset.area   || '') === area;
                var matchRol    = !rol    || (tr.dataset.rol    || '') === rol;
                var matchEstado = !estado || (tr.dataset.estado || '') === estado;
                var mostrar = matchTexto && matchArea && matchRol && matchEstado;
                tr.style.display = mostrar ? '' : 'none';
                if (mostrar) visible++;
            });
            if (contador) contador.textContent = visible;
        }

        function limpiarFiltros() {
            filtroNombre.value = '';
            filtroArea.value   = '';
            filtroRol.value    = '';
            filtroEstado.value = '';
            filtrar();
        }

        filtroNombre.addEventListener('input',  filtrar);
        filtroArea.addEventListener('change',   filtrar);
        filtroRol.addEventListener('change',    filtrar);
        filtroEstado.addEventListener('change', filtrar);
    </script>
}
