@{
    ViewData["Title"] = "Salas de Reuniones";

    var semana = ViewBag.Semana as List<DateOnly> ?? new List<DateOnly>();
    var salas = ViewBag.Salas as List<Farmacol.Models.TbSala> ?? new List<Farmacol.Models.TbSala>();
    var reservas = ViewBag.Reservas as List<Farmacol.Models.TbReservaSala> ?? new List<Farmacol.Models.TbReservaSala>();
    var hoy = (DateOnly)(ViewBag.Hoy ?? DateOnly.FromDateTime(DateTime.Today));
    var lunes = (DateOnly)(ViewBag.Lunes ?? hoy);
    var esGestor = (bool)(ViewBag.EsGestor ?? false);

    var cult = new System.Globalization.CultureInfo("es-CO");
}

<style>
    .sala-colombia { background-color: #f1c40f22 !important; border-left: 5px solid #f1c40f; }
    .sala-vasoton  { background-color: #e74c3c22 !important; border-left: 5px solid #e74c3c; }
    .sala-apifolt  { background-color: #9b59b622 !important; border-left: 5px solid #9b59b6; }

    .reserva-item {
        background: #f0fdf4;
        border: 1px solid #86efac;
        border-radius: 6px;
        padding: 6px 8px;
        margin-bottom: 4px;
        font-size: 0.85rem;
        text-align: left;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">📅 Salas de Reuniones</h2>
        <small class="text-muted">Reserva salas de lunes a viernes entre 7:00 am y 4:00 pm</small>
    </div>
    <div class="d-flex gap-2">
        @if (esGestor)
        {
            <a asp-action="Gestion" class="btn btn-warning btn-sm">⚙️ Gestionar reservas</a>
        }
        <a asp-action="MisReservas" class="btn btn-outline-primary btn-sm">📋 Mis reservas</a>
        <a asp-action="Solicitar" class="btn btn-primary btn-sm">➕ Nueva reserva</a>
    </div>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<!-- Navegación de semana -->
<div class="card mb-3">
    <div class="card-body py-2">
        <div class="d-flex align-items-center justify-content-between">
            <a asp-action="Index" asp-route-fecha="@lunes.AddDays(-7).ToString("yyyy-MM-dd")" 
               class="btn btn-sm btn-outline-secondary">◀ Anterior</a>
            
            <span class="fw-bold fs-5">
                @lunes.ToString("dd MMM", cult) — @lunes.AddDays(6).ToString("dd MMM yyyy", cult)
            </span>
            
            <a asp-action="Index" asp-route-fecha="@lunes.AddDays(7).ToString("yyyy-MM-dd")" 
               class="btn btn-sm btn-outline-secondary">Siguiente ▶</a>
        </div>
    </div>
</div>

<!-- Calendario -->
<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-bordered mb-0 text-center small">
            <thead class="table-dark">
                <tr>
                    <th style="width: 140px;">Sala</th>
                    @foreach (var dia in semana)
                    {
                        var esHoy = dia == hoy;
                        <th style="background: @(esHoy ? "#dbeafe" : "#f8f9fa"); color: @(esHoy ? "#1e40af" : "#374151");">
                            <div class="fw-bold">@dia.ToString("ddd", cult).ToUpper()</div>
                            <div>@dia.ToString("dd/MM")</div>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var sala in salas)
                {
                    string claseSala = sala.Nombre.ToLower() switch
                    {
                        var n when n.Contains("colombia") => "sala-colombia",
                        var n when n.Contains("vasoton")  => "sala-vasoton",
                        var n when n.Contains("apifolt")  => "sala-apifolt",
                        _ => ""
                    };

                    <tr>
                        <td class="fw-semibold align-middle @claseSala" style="background:#f8fafc;">
                            @sala.Nombre
                        </td>

                        @foreach (var dia in semana)
                        {
                            var reservasDia = reservas
                                .Where(r => r.SalaId == sala.Id && r.Fecha == dia)
                                .OrderBy(r => r.HoraInicio)
                                .ToList();

                            var esPasado = dia < hoy;
                            var esHabil = dia.DayOfWeek != DayOfWeek.Saturday && dia.DayOfWeek != DayOfWeek.Sunday;

                            <td class="p-2 align-top" style="min-width: 110px; background:@(dia == hoy ? "#f0f9ff" : "#fff"); @(esPasado ? "opacity:0.6;" : "")">

                                @foreach (var r in reservasDia)
                                {
                                    if (r.Estado == "Aprobada")
                                    {
                                        <div class="reserva-item mb-1">
                                            <strong>@r.NombreSolicitante</strong><br>
                                            <small>@r.HoraInicio.ToString("HH:mm") - @r.HoraFin.ToString("HH:mm")</small>
                                        </div>
                                    }
                                }

                                @if (!esPasado && esHabil)
                                {
                                    <a asp-action="Solicitar" 
                                       asp-route-salaId="@sala.Id"
                                       asp-route-fecha="@dia.ToString("yyyy-MM-dd")"
                                       class="btn btn-sm w-100 mt-2 text-success fw-semibold"
                                       style="background:#f0fdf4; border:1px dashed #86efac;">
                                        + Reservar
                                    </a>
                                }
                                else if (!esPasado && !esHabil)
                                {
                                    <div class="text-center text-muted py-3" style="font-size:0.75rem;">
                                        Solo días hábiles
                                    </div>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3 small text-muted">
    💡 Solo se permiten reservas de <strong>lunes a viernes</strong> entre las <strong>7:00 am y 4:00 pm</strong>.
</div>