@using Farmacol.Models
@model IEnumerable<TbReservaSala>
@{
    ViewData["Title"] = "Mis Reservas de Sala";
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Volver al calendario</a>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">📋 Mis Reservas</h2>
    <a asp-action="Solicitar" class="btn btn-primary btn-sm">➕ Nueva reserva</a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Exito"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <div style="font-size:3rem">📭</div>
            <h5 class="mt-3 text-muted">Sin reservas registradas</h5>
            <a asp-action="Solicitar" class="btn btn-primary mt-2">➕ Solicitar una sala</a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 small">
                <thead class="table-dark">
                    <tr>
                        <th>Sala</th>
                        <th>Fecha</th>
                        <th>Horario</th>
                        <th>Motivo</th>
                        <th>Estado</th>
                        <th>Observación</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var badge = r.Estado switch
                        {
                                    "Aprobada" => "success",
                                    "Rechazada" => "danger",
                                    "Devuelta" => "warning",
                            _ => "secondary"
                        };
                        <tr>
                            <td><strong>@r.Sala?.Nombre</strong></td>
                            <td>@r.Fecha.ToString("dd/MM/yyyy")</td>
                            <td class="font-monospace">
                                @r.HoraInicio.ToString("HH:mm") – @r.HoraFin.ToString("HH:mm")
                            </td>
                            <td class="text-muted" style="max-width:200px">
                                <span class="d-block text-truncate" title="@r.Motivo">@r.Motivo</span>
                            </td>
                            <td><span class="badge bg-@badge">@r.Estado</span></td>
                            <td><small class="text-muted">@r.Observacion</small></td>
                            <td class="text-center">
                                @{
                                    var hoy = DateOnly.FromDateTime(DateTime.Today);
                                    var ahora = TimeOnly.FromDateTime(DateTime.Now);
                                    var puedeCancelar = (r.Estado == "Aprobada" || r.Estado == "Pendiente" || r.Estado == "Devuelta") &&
                                                        (r.Fecha > hoy || (r.Fecha == hoy && r.HoraInicio > ahora));
                                }

                                @if (puedeCancelar)
                                {
                                    <form asp-action="Cancelar" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('¿Cancelar esta reserva?')">
                                            🗑️ Cancelar
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <small class="text-muted">No cancelable</small>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}