@model IEnumerable<Farmacol.Models.TbSalidaEquipos>
@{
    ViewData["Title"] = "Revisar salidas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">📋 Revisar Salidas de Equipos</h2>
        <a asp-action="Create" asp-controller="SalidaEquipos" class="btn btn-sm btn-primary">➕ Nueva salida</a>
    </div>

    @if (!Model?.Any() ?? true)
    {
        <div class="alert alert-info">No hay salidas registradas.</div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 small">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Solicitante</th>
                            <th>Área</th>
                            <th>Fecha registro</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Solicitante</td>
                                <td>@item.Area</td>
                                <td>@(item.FechaRegistro.HasValue ? item.FechaRegistro.Value.ToString("dd MMM, yyyy") : "-")</td>
                                <td>@(item.Estado ?? "-")</td>
                                <td class="text-end">
                                    @* Only show Revisar link to roles that can access it *@
                                    @if (User.IsInRole("Gerente") || User.IsInRole("Jefe") || User.IsInRole("RRHH") || User.IsInRole("Administrador") || User.IsInRole("Gerente Capital Humano"))
                                    {
                                        <a asp-action="Revisar" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Revisar</a>
                                    }
                                    <a asp-action="Create" asp-controller="SalidaEquipos" class="btn btn-sm btn-outline-secondary ms-2">Duplicar</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
