@model IEnumerable<Farmacol.Models.TbSalidaEquipos>
@{
    ViewData["Title"] = "Vigilancia - Salidas completas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">🔒 Vigilancia — Salidas completadas</h2>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No hay salidas completadas.</div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 small">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Solicitante</th>
                            <th>Área</th>
                            <th>Fecha registro</th>
                            <th>Fecha aprobación CH</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td>@s.Id
                                <td>@s.Solicitante</td>
                                <td>@s.Area</td>
                                <td>@(s.FechaRegistro.HasValue ? s.FechaRegistro.Value.ToString("dd/MM/yyyy") : "-")</td>
                                <td>@(s.FechaAprobacionCH.HasValue ? s.FechaAprobacionCH.Value.ToString("dd/MM/yyyy HH:mm") : "-")</td>
                                <td>
                                    <a href="/SalidaEquipos/Revisar?id=@s.Id" class="btn btn-action btn-sm px-3 text-primary fw-bold" title="Ver">
                                        <i class="bi bi-eye me-1"></i> Ver
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
