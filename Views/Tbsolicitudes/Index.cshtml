@model IEnumerable<Farmacol.Models.Tbsolicitude>
@{
    ViewData["Title"] = "Solicitudes";
    bool esAdmin = User.IsInRole("Administrador");
    bool esRRHH = User.IsInRole("RRHH");
    bool esGerente = User.IsInRole("Gerente");
    bool esJefe = User.IsInRole("Jefe");
    bool esCoord = User.IsInRole("Coordinador");
    bool esAsistente = User.IsInRole("Asistente");
    bool esDirectivo = User.IsInRole("Directivo");
    string userArea = ViewBag.UserArea as string ?? "";
    bool esCapHumano = userArea == "Capital Humano";
    int? userCC = ViewBag.UserCC as int?;

    bool esGerenteCH = (esGerente && esCapHumano) || esAdmin || esRRHH;

    bool puedeRevisar = esRRHH || esDirectivo || esJefe
                     || (esGerente && !esCapHumano)  
                     || (esGerente && esCapHumano)     
                     || (esCoord && esCapHumano)
                     || (esAsistente && esCapHumano);

    bool puedeCrear = esAdmin || esRRHH
                   || (esCoord && esCapHumano)
                   || (esAsistente && esCapHumano);

    bool verFiltros = esAdmin || esRRHH || esDirectivo || esGerente || esJefe
                   || (esCoord && esCapHumano)
                   || (esAsistente && esCapHumano);
}

<h1>Solicitudes</h1>

<div class="d-flex gap-2 mb-3">
    <a asp-action="ExportarExcel"
       asp-route-busqueda="@ViewBag.Busqueda"
       asp-route-estado="@ViewBag.Estado"
       class="btn btn-success btn-sm">
        📥 Exportar filtrado
    </a>
    <a asp-action="ExportarExcel" asp-route-todo="true"
       class="btn btn-outline-success btn-sm">
        📥 Exportar todo
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (puedeCrear)
{
    <p><a asp-action="Create" class="btn btn-primary">+ Nueva</a></p>
}

@if (verFiltros)
{
    <form method="get" class="mb-3">
        <div class="row g-2">
            <div class="col-md-3">
                <input type="text" name="busqueda" value="@ViewBag.Busqueda"
                       class="form-control" placeholder="🔍 Buscar en todo..." />
            </div>
            <div class="col-md-2">
                <input type="text" name="cedula" value="@ViewBag.Cedula"
                       class="form-control" placeholder="CC" />
            </div>
            <div class="col-md-2">
                <input type="text" name="nombre" value="@ViewBag.Nombre"
                       class="form-control" placeholder="Nombre" />
            </div>
            <div class="col-md-2">
                <select name="tipoSolicitud" class="form-select">
                    <option value="">Todos los tipos</option>
                    <option value="Permiso" selected="@(ViewBag.TipoSolicitud == "Permiso")">Permiso</option>
                    <option value="Vacaciones" selected="@(ViewBag.TipoSolicitud == "Vacaciones")">Vacaciones</option>
                    <option value="Documental" selected="@(ViewBag.TipoSolicitud == "Documental")">📄 Documental</option>
                </select>
            </div>
            <div class="col-md-2">
                <select name="estado" class="form-select">
                    <option value="">Todos los estados</option>
                    <option value="En proceso">En proceso</option>
                    <option value="Pendiente">Pendiente</option>
                    <option value="Aprobada">Aprobada</option>
                    <option value="Rechazada">Rechazada</option>
                    <option value="Devuelta">Devuelta</option>
                    <option value="Finalizada">Finalizada</option>
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-secondary w-100">Filtrar</button>
            </div>
            <div class="col-md-1">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">✕</a>
            </div>
        </div>
    </form>
}

@if (!Model.Any())
{
    <div class="alert alert-info">No hay solicitudes para mostrar.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Cargo</th>
                    <th>Tipo</th>
                    <th>Subtipo</th>
                    <th>Fecha</th>
                    <th>Días/Horas</th>
                    <th>Etapa actual</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.IdSolicitud</td>
                        <td>@item.Nombre</td>
                        <td><small>@item.Cargo</small></td>
                        <td>
                            @if (item.TipoSolicitud == "Vacaciones")
                            {
                                <span class="badge bg-success">🏖️ Vacaciones</span>
                            }
                            else if (item.TipoSolicitud == "Documental")
                            {
                                <span class="badge bg-info text-dark">📄 Documental</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">🕐 Permiso</span>
                            }
                        </td>
                        <td>
                            @if (item.TipoSolicitud == "Documental")
                            {
                                <small>@item.DocumentoSolicitado</small>
                            }
                            else
                            {
                                <small>@item.SubtipoPermiso</small>
                            }
                        </td>
                        <td>@item.FechaSolicitud</td>
                        <td>
                            @if (item.TotalHoras != null)
                            {
                                <small>@item.TotalHoras hrs</small>
                            }
                            else if (item.TotalDias != null)
                            {
                                <small>@item.TotalDias días</small>
                            }
                        </td>
                        <td><small class="text-muted">@item.EtapaAprobacion</small></td>
                        <td>
                            @{
                                var badgeEstado = item.Estado switch
                                {
                                    "Aprobada" => "bg-success",
                                    "Rechazada" => "bg-danger",
                                    "Devuelta" => "bg-warning text-dark",
                                    "Finalizada" => "bg-secondary",
                                    "Pendiente" => "bg-warning text-dark",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeEstado">@item.Estado</span>
                         </td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                <a asp-action="Detalle" asp-route-id="@item.IdSolicitud"
                                   class="btn btn-sm btn-outline-secondary">👁️ Ver</a>

                                @if (puedeRevisar && item.Estado == "En proceso" && item.TipoSolicitud != "Documental")
                                {
                                    <a asp-action="Revisar" asp-route-id="@item.IdSolicitud"
                                       class="btn btn-sm btn-warning">⚡ Revisar</a>
                                }

                                @if (item.TipoSolicitud == "Documental" && item.Estado == "Pendiente" && esGerenteCH)
                                {
                                    <a asp-controller="SolicitudRRHH" asp-action="RevisarDocumento" asp-route-id="@item.IdSolicitud"
                                       class="btn btn-sm btn-primary">📄 Gestionar</a>
                                }

                                @if (item.Estado == "Devuelta" && userCC.HasValue && item.CC == userCC.Value)
                                {
                                    <a asp-action="Editar" asp-route-id="@item.IdSolicitud"
                                       class="btn btn-sm btn-info">✏️ Editar</a>
                                }

                                @if (esAdmin)
                                {
                                    <a asp-action="Delete" asp-route-id="@item.IdSolicitud"
                                       class="btn btn-sm btn-outline-danger">🗑️ Eliminar</a>
                                }
                            </div>
                         </td>
                     </tr>
                }
            </tbody>
        </table>
    </div>
}