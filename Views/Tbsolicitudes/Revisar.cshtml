@model Farmacol.Models.Tbsolicitude
@{
    ViewData["Title"] = "Revisar Solicitud";
    bool puedeActuar = (bool)(ViewBag.PuedeActuar ?? false);
    bool esAdmin = User.IsInRole("Administrador");
    bool esRRHH = User.IsInRole("RRHH");
    bool esAdminRRHH = esAdmin || esRRHH;
    string userArea = ViewBag.UserArea as string ?? "";
    bool esCapHumano = userArea == "Capital Humano";
    bool puedeDevolver = esAdminRRHH || esCapHumano;

    // Lógica de color de banner
    string bannerClass = Model.Estado == "Aprobada" ? "border-success bg-success-subtle text-success" :
                        Model.Estado == "Rechazada" ? "border-danger bg-danger-subtle text-danger" :
                        Model.Estado == "Devuelta" ? "border-warning bg-warning-subtle text-warning-emphasis" :
                        "border-primary bg-primary-subtle text-primary";
}

<div class="container py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-action="Index">Solicitudes</a></li>
                    <li class="breadcrumb-item active">Revisión</li>
                </ol>
            </nav>
            <h2 class="h3 mb-0">Solicitud <span class="text-primary">#@Model.IdSolicitud</span></h2>
        </div>
        <div class="border rounded px-3 py-2 fw-bold @bannerClass">
            Estado: @Model.Estado?.ToUpper()
        </div>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0"><i class="bi bi-person-lines-fill me-2"></i>Detalles del Solicitante</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <tbody class="border-top-0">
                                <tr>
                                    <td class="text-muted ps-4" style="width: 35%;">Solicitante</td>
                                    <td class="fw-bold pe-4">@Model.Nombre <span class="badge bg-light text-dark border ms-2">CC: @Model.CC</span></td>
                                </tr>
                                <tr>
                                    <td class="text-muted ps-4">Cargo / Nivel</td>
                                    <td class="pe-4">@Model.Cargo <span class="text-muted">|</span> @Model.NivelSolicitante</td>
                                </tr>
                                <tr>
                                    <td class="text-muted ps-4">Tipo de Solicitud</td>
                                    <td class="pe-4">
                                        <span class="badge bg-primary">@Model.TipoSolicitud</span>
                                        @if (!string.IsNullOrEmpty(Model.SubtipoPermiso))
                                        {
                                            <span class="badge bg-info text-dark">@Model.SubtipoPermiso</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-muted ps-4">Periodo</td>
                                    <td class="pe-4">
                                        <div class="d-flex gap-3">
                                            <span><strong>Inicio:</strong> @(Model.FechaInicio?.ToString("dd/MM/yyyy") ?? "-") @Model.HoraInicio</span>
                                            <span><strong>Fin:</strong> @(Model.FechaFin?.ToString("dd/MM/yyyy") ?? "-") @Model.HoraFin</span>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-muted ps-4">Cálculo</td>
                                    <td class="pe-4 text-primary fw-bold">
                                        @if (Model.TotalDias.HasValue && Model.TotalDias > 0)
                                        {
                                            @Model.TotalDias.Value.ToString("0.##")<text> Días</text>
                                        }
                                        @if (Model.TotalHoras.HasValue && Model.TotalHoras > 0)
                                        {
                                            if (Model.TotalDias.HasValue && Model.TotalDias > 0) { <text> / </text> }
                                            @Model.TotalHoras.Value.ToString("0.##")<text> Horas</text>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-muted ps-4">Motivo / Obs.</td>
                                    <td class="pe-4">
                                        <strong>@Model.Motivo</strong><br />
                                        <small class="text-muted">@Model.Observaciones</small>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Anexos))
            {
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">📎 Documentos Adjuntos</h5>
                        <a href="@Model.Anexos" target="_blank" class="btn btn-sm btn-outline-primary">Ver pantalla completa</a>
                    </div>
                    <div class="card-body p-2">
                        <div class="ratio ratio-16x9 border rounded overflow-hidden shadow-sm" style="--bs-aspect-ratio: 60%;">
                            <iframe src="@Model.Anexos" style="border:none;"></iframe>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3 text-center">
                    <h5 class="card-title mb-0">Estatus de Aprobación</h5>
                </div>
                <div class="card-body">
                    <div class="timeline-steps">
                        @for (int i = 1; i <= (Model.TotalPasos ?? 0); i++)
                        {
                            var cargo = i == 1 ? Model.Paso1Aprobador : i == 2 ? Model.Paso2Aprobador : Model.Paso3Aprobador;
                            var estado = i == 1 ? Model.Paso1Estado : i == 2 ? Model.Paso2Estado : Model.Paso3Estado;
                            var obs = i == 1 ? Model.Paso1Obs : i == 2 ? Model.Paso2Obs : Model.Paso3Obs;

                            var isCurrent = i == Model.PasoActual && Model.Estado == "En proceso";
                            var color = estado == "Aprobado" ? "success" :
                                        estado == "Rechazado" ? "danger" :
                                        estado == "Devuelta" || estado == "Pendiente" ? "warning" : "secondary";

                            <div class="d-flex mb-4 position-relative">
                                <div class="timeline-icon bg-@color shadow-sm rounded-circle d-flex align-items-center justify-content-center text-white" style="width: 40px; height: 40px; z-index: 2;">
                                    @if(estado == "Aprobado") { <i class="bi bi-check-lg"></i> }
                                    else if(isCurrent) { <i class="bi bi-play-fill text-white pulse"></i> }
                                    else { <i class="bi bi-clock"></i> }
                                </div>
                                <div class="ms-3 flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <h6 class="mb-0 @(isCurrent ? "text-primary fw-bold" : "")">Paso @i: @cargo</h6>
                                        <span class="badge rounded-pill bg-@color-subtle text-@color border border-@color">@estado</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(obs))
                                    {
                                        <div class="bg-light rounded p-2 mt-2 small border-start border-3 border-@color">
                                            <i class="bi bi-chat-left-text me-1"></i> @obs
                                        </div>
                                    }
                                </div>
                                @if (i < Model.TotalPasos) { <div class="position-absolute border-start" style="left: 20px; top: 40px; height: 100%; z-index: 1;"></div> }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="sticky-top" style="top: 80px; z-index: 100;">
                @if (puedeActuar && Model.Estado == "En proceso")
                {
                    <div class="accordion shadow-sm" id="accAcciones">
                        <div class="accordion-item border-success overflow-hidden">
                            <h2 class="accordion-header">
                                <button class="accordion-button bg-success text-white fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#colAprobar">
                                    ✅ Aprobar Solicitud
                                </button>
                            </h2>
                            <div id="colAprobar" class="accordion-collapse collapse show" data-bs-parent="#accAcciones">
                                <div class="accordion-body">
                                    <form asp-action="Aprobar" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@Model.IdSolicitud" />
                                        <textarea name="observacion" class="form-control mb-3" rows="2" placeholder="Observaciones (opcional)"></textarea>
                                        <button type="submit" class="btn btn-success w-100 py-2">Confirmar Aprobación</button>
                                    </form>
                                </div>
                            </div>
                        </div>

                        @if (puedeDevolver)
                        {
                            <div class="accordion-item border-warning overflow-hidden">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed bg-warning text-dark fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#colDevolver">
                                        ↩️ Devolver para corrección
                                    </button>
                                </h2>
                                <div id="colDevolver" class="accordion-collapse collapse" data-bs-parent="#accAcciones">
                                    <div class="accordion-body bg-warning-subtle">
                                        <form asp-action="Devolver" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@Model.IdSolicitud" />
                                            <textarea name="observacion" class="form-control mb-3" rows="3" required minlength="10" placeholder="¿Qué debe corregir el colaborador?"></textarea>
                                            <button type="submit" class="btn btn-warning w-100 py-2 fw-bold text-dark border-dark-subtle">Ejecutar Devolución</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="accordion-item border-danger overflow-hidden">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed bg-danger text-white fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#colRechazar">
                                    ❌ Rechazar Permanentemente
                                </button>
                            </h2>
                            <div id="colRechazar" class="accordion-collapse collapse" data-bs-parent="#accAcciones">
                                <div class="accordion-body">
                                    <form asp-action="Rechazar" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@Model.IdSolicitud" />
                                        <textarea name="observacion" class="form-control mb-3" rows="3" required placeholder="Motivo del rechazo..."></textarea>
                                        <button type="submit" class="btn btn-danger w-100 py-2">Confirmar Rechazo</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card shadow-sm border-0 bg-light text-center py-4 px-3">
                        <i class="bi bi-info-circle fs-2 text-muted mb-2"></i>
                        <h6 class="text-muted mb-0">Esta solicitud no requiere tu intervención.</h6>
                        <small class="text-secondary mt-1">@Model.Estado - @Model.EtapaAprobacion</small>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .bg-success-subtle { background-color: #d1e7dd; }
    .bg-danger-subtle { background-color: #f8d7da; }
    .bg-warning-subtle { background-color: #fff3cd; }
    .bg-primary-subtle { background-color: #cfe2ff; }
    
    .timeline-icon i { font-size: 1.2rem; }
    
    .pulse {
        animation: pulse-animation 2s infinite;
    }

    @@keyframes pulse-animation {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(13, 110, 253, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(13, 110, 253, 0); }
    }

    .accordion-button:not(.collapsed) {
        box-shadow: none;
    }
</style>