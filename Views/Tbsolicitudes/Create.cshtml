@model Farmacol.Models.Tbsolicitude
@{
    ViewData["Title"] = "Nueva Solicitud";
    bool esAdminRRHH = User.IsInRole("Administrador") || User.IsInRole("RRHH");
}

<h1>Nueva Solicitud</h1>
<hr />

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}

<!-- SELECTOR TIPO -->
<div class="mb-4">
    <label class="form-label fw-bold fs-5">¿Qué tipo de solicitud deseas crear?</label>
    <div class="d-flex gap-3 mt-2">
        <button type="button" class="btn btn-outline-primary btn-lg px-5"
                onclick="mostrarFormulario('permiso')">
            🕐 Permiso
        </button>
        <button type="button" class="btn btn-outline-success btn-lg px-5"
                onclick="mostrarFormulario('vacaciones')">
            🏖️ Vacaciones
        </button>
    </div>
</div>

@* El bloque de información de Vacaciones se muestra dentro del formulario de Vacaciones cuando el usuario lo selecciona *@
<!-- FORMULARIO PERMISO -->
<div id="formPermiso" style="display:none">
    <h4 class="text-primary mb-3">📋 Solicitud de Permiso</h4>
    <form asp-action="Create" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="TipoSolicitud" value="Permiso" />
        <input type="hidden" name="Estado" value="En proceso" />
        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-2">
                    <label class="control-label">CC</label>
                    <input name="CC" class="form-control"
                           value="@ViewBag.CedulaActual"
                           @(esAdminRRHH ? "" : "readonly") />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Nombre</label>
                    <input name="Nombre" class="form-control"
                           value="@ViewBag.NombreActual"
                           @(esAdminRRHH ? "" : "readonly") />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Cargo</label>
                    <input name="Cargo" class="form-control"
                           value="@ViewBag.CargoActual"
                           @(esAdminRRHH ? "" : "readonly") />
                </div>

                @* Área: solo visible para Admin/RRHH que crean en nombre de otro *@
                @if (esAdminRRHH)
                {
                    <div class="form-group mb-2">
                        <label class="control-label">Área del solicitante</label>
                        <input name="AreaSolicitante" class="form-control"
                               placeholder="Se obtiene automáticamente del perfil" readonly
                               value="@ViewBag.AreaActual" />
                    </div>
                }

                <div class="form-group mb-2">
                    <label class="control-label">Tipo de Permiso</label>
                    <select name="SubtipoPermiso" class="form-select">
                        <option value="">-- Selecciona --</option>
                        @if (ViewBag.SubtiposPermiso != null)
                        {
                            foreach (var s in ViewBag.SubtiposPermiso)
                            {
                                <option value="@s.Nombre">@s.Nombre</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Motivo (opcional)</label>
                    <textarea name="Motivo" class="form-control" rows="2"></textarea>
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Observaciones (opcional)</label>
                    <textarea name="Observaciones" class="form-control" rows="2"></textarea>
                </div>

                @* Info del flujo que se asignará automáticamente *@
                <div class="alert alert-info py-2 mt-2">
                    <small>
                        🔄 El flujo de aprobación se asignará automáticamente
                        según tu área y cargo al enviar la solicitud.
                    </small>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-2">
                    <label class="control-label">Hora Inicio</label>
                    <input name="HoraInicio" id="horaInicioP" type="time"
                           class="form-control" oninput="calcularHoras()" />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Hora Fin</label>
                    <input name="HoraFin" id="horaFinP" type="time"
                           class="form-control" oninput="calcularHoras()" />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Total Horas</label>
                    <input name="TotalHoras" id="totalHorasP" class="form-control" readonly />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Fecha Inicio (opcional)</label>
                    <input name="FechaInicio" id="fechaInicioP" type="date"
                           class="form-control" oninput="calcularDiasPermiso()" />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Fecha Fin (opcional)</label>
                    <input name="FechaFin" id="fechaFinP" type="date"
                           class="form-control" oninput="calcularDiasPermiso()" />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Total Días</label>
                    <input name="TotalDias" id="totalDiasP" class="form-control" readonly />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Fecha Solicitud</label>
                    <input name="FechaSolicitud" class="form-control" type="date"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" readonly />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Anexo (PDF)</label>
                    <input type="file" name="archivoAnexo" accept=".pdf" class="form-control" />
                </div>
                @if (esAdminRRHH)
                {
                    <div class="form-group mb-2">
                        <label class="control-label">Estado</label>
                        <select name="Estado" class="form-select">
                            <option value="En proceso">En proceso</option>
                            <option value="Aprobada">Aprobada</option>
                            <option value="Rechazada">Rechazada</option>
                        </select>
                    </div>
                    <div class="form-group mb-2">
                        <label class="control-label">Aprobación Jefe</label>
                        <input name="AprobJinmediato" class="form-control" />
                    </div>
                    <div class="form-group mb-2">
                        <label class="control-label">Aprobación CH</label>
                        <input name="AprobCh" class="form-control" />
                    </div>
                }
            </div>
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Enviar Solicitud</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>

<!-- FORMULARIO VACACIONES -->
<div id="formVacaciones" style="display:none">
    <h4 class="text-success mb-3">🏖️ Solicitud de Vacaciones</h4>
    <form asp-action="Create" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="TipoSolicitud" value="Vacaciones" />
        <input type="hidden" name="FechaInicio" id="inputFechaInicio" />
        <input type="hidden" name="FechaFin" id="inputFechaFin" />
        <input type="hidden" name="TotalDias" id="inputTotalDias" />
        <input type="hidden" name="FechaSolicitud" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="Estado" value="En proceso" />

        <div class="row">
            <div class="col-md-5">
                <div class="form-group mb-2">
                    <label class="control-label">CC</label>
                    <input name="CC" class="form-control"
                           value="@ViewBag.CedulaActual"
                           @(esAdminRRHH ? "" : "readonly") />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Nombre</label>
                    <input name="Nombre" class="form-control"
                           value="@ViewBag.NombreActual"
                           @(esAdminRRHH ? "" : "readonly") />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Cargo</label>
                    <input name="Cargo" class="form-control"
                           value="@ViewBag.CargoActual"
                           @(esAdminRRHH ? "" : "readonly") />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Total Días</label>
                    <input id="totalDiasDisplay" class="form-control" readonly
                           placeholder="Se calcula al elegir fechas" />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Días disponibles</label>
                    <input id="diasDisponiblesDisplay" class="form-control" readonly
                           value="@(ViewBag.Vacaciones?.DiasDisponibles ?? 0)" />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Días restantes tras solicitud</label>
                    <input id="diasRestantesDisplay" class="form-control" readonly value="" />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Fecha Solicitud</label>
                    <input class="form-control" type="date"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" readonly />
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Observaciones (opcional)</label>
                    <textarea name="Observaciones" class="form-control" rows="3"></textarea>
                </div>
                <div class="form-group mb-2">
                    <label class="control-label">Anexo (PDF)</label>
                    <input type="file" name="archivoAnexo" accept=".pdf" class="form-control" />
                </div>

                <div class="alert alert-info py-2">
                    <small>
                        🔄 El flujo de aprobación se asignará automáticamente
                        según tu área y cargo al enviar la solicitud.
                    </small>
                </div>

                @if (esAdminRRHH)
                {
                    <div class="form-group mb-2">
                        <label class="control-label">Estado</label>
                        <select name="Estado" class="form-select">
                            <option value="En proceso">En proceso</option>
                            <option value="Aprobada">Aprobada</option>
                            <option value="Rechazada">Rechazada</option>
                        </select>
                    </div>
                }
            </div>
            <div class="col-md-7">
                <label class="control-label fw-bold">Selecciona las fechas de vacaciones</label>
                <div class="mt-2 d-flex gap-3 mb-3">
                    <span class="badge bg-primary p-2 fs-6">🔵 Inicio: <span id="lblInicio">No seleccionado</span></span>
                    <span class="badge bg-danger p-2 fs-6">🔴 Fin: <span id="lblFin">No seleccionado</span></span>
                </div>
                <div id="calendarioVacaciones" class="border rounded p-3"></div>
            </div>
        </div>
        <div class="mt-3">
            <div id="vacWarning" class="alert alert-danger d-none">❌ No tienes suficientes días disponibles para el rango seleccionado.</div>
            <button type="submit" id="vacSubmit" class="btn btn-success">Enviar Solicitud</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <style>
        .cal-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 4px;
        }

        .cal-header-row {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 4px;
            margin-bottom: 6px;
        }

        .cal-day {
            padding: 8px 4px;
            text-align: center;
            border-radius: 6px;
            cursor: pointer;
            border: 1px solid #dee2e6;
            font-size: 0.9rem;
            transition: all 0.15s;
        }

            .cal-day:hover {
                background: #e9ecef;
            }

            .cal-day.inicio {
                background: #0d6efd !important;
                color: white !important;
                border-color: #0d6efd !important;
            }

            .cal-day.fin {
                background: #dc3545 !important;
                color: white !important;
                border-color: #dc3545 !important;
            }

            .cal-day.rango {
                background: #cfe2ff;
                border-color: #9ec5fe;
            }

            .cal-day.vacio {
                border: none;
                cursor: default;
            }

        .cal-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }
    </style>

    <script>
        // Valor de días disponibles calculado en servidor
        var serverDiasDisponibles = Number('@(ViewBag.Vacaciones?.DiasDisponibles ?? 0)'.replace(',', '.')) || 0;

        function mostrarFormulario(tipo) {
            document.getElementById('formPermiso').style.display    = tipo === 'permiso'    ? 'block' : 'none';
            document.getElementById('formVacaciones').style.display = tipo === 'vacaciones' ? 'block' : 'none';
            if (tipo === 'vacaciones') {
                // Mostrar valores iniciales antes de abrir calendario
                var dispEl = document.getElementById('diasDisponiblesDisplay');
                var restEl = document.getElementById('diasRestantesDisplay');
                var warningEl = document.getElementById('vacWarning');
                var submitBtn = document.getElementById('vacSubmit');
                if (dispEl) dispEl.value = (Math.floor(serverDiasDisponibles) || 0) + ' días';
                if (restEl) restEl.value = (Math.floor(serverDiasDisponibles) || 0) + ' días';
                if (warningEl) warningEl.classList.add('d-none');
                if (submitBtn) submitBtn.disabled = false;
                renderCalendario();
            }
        }

        function calcularHoras() {
            const inicio = document.getElementById('horaInicioP').value;
            const fin    = document.getElementById('horaFinP').value;
            if (inicio && fin) {
                const [h1, m1] = inicio.split(':').map(Number);
                const [h2, m2] = fin.split(':').map(Number);
                const totalMin = (h2 * 60 + m2) - (h1 * 60 + m1);
                document.getElementById('totalHorasP').value = totalMin > 0 ? (totalMin / 60).toFixed(1) : '';
            }
        }

        function calcularDiasPermiso() {
            const inicio = document.getElementById('fechaInicioP').value;
            const fin    = document.getElementById('fechaFinP').value;
            if (inicio && fin && fin >= inicio) {
                const diff = Math.round((new Date(fin) - new Date(inicio)) / (1000*60*60*24)) + 1;
                document.getElementById('totalDiasP').value = diff;
            } else {
                document.getElementById('totalDiasP').value = '';
            }
        }

        let fechaInicio = null, fechaFin = null;
        let calYear = new Date().getFullYear(), calMonth = new Date().getMonth();
        const meses   = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
        const diasSem = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];

        function renderCalendario() {
            const cont      = document.getElementById('calendarioVacaciones');
            const primerDia = new Date(calYear, calMonth, 1).getDay();
            const totalDias = new Date(calYear, calMonth + 1, 0).getDate();
            let html = `
                <div class="cal-nav">
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="cambiarMes(-1)">◀</button>
                    <strong>${meses[calMonth]} ${calYear}</strong>
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="cambiarMes(1)">▶</button>
                </div>
                <div class="cal-header-row">${diasSem.map(d=>`<div class="text-center fw-bold small text-muted">${d}</div>`).join('')}</div>
                <div class="cal-grid">`;
            for (let i = 0; i < primerDia; i++) html += `<div class="cal-day vacio"></div>`;
            for (let d = 1; d <= totalDias; d++) {
                const fechaStr = new Date(calYear, calMonth, d).toISOString().split('T')[0];
                let clase = 'cal-day';
                if (fechaInicio && fechaStr === fechaInicio) clase += ' inicio';
                else if (fechaFin && fechaStr === fechaFin)  clase += ' fin';
                else if (fechaInicio && fechaFin && fechaStr > fechaInicio && fechaStr < fechaFin) clase += ' rango';
                html += `<div class="${clase}" onclick="seleccionarFecha('${fechaStr}')">${d}</div>`;
            }
            html += `</div>`;
            cont.innerHTML = html;
        }

        function cambiarMes(dir) {
            calMonth += dir;
            if (calMonth > 11) { calMonth = 0; calYear++; }
            if (calMonth < 0)  { calMonth = 11; calYear--; }
            renderCalendario();
        }

        function seleccionarFecha(fechaStr) {
            if (!fechaInicio || (fechaInicio && fechaFin)) {
                fechaInicio = fechaStr; fechaFin = null;
            } else if (fechaStr > fechaInicio) {
                fechaFin = fechaStr;
            } else {
                fechaInicio = fechaStr; fechaFin = null;
            }
            document.getElementById('inputFechaInicio').value = fechaInicio ?? '';
            document.getElementById('inputFechaFin').value    = fechaFin    ?? '';
            document.getElementById('lblInicio').textContent  = fechaInicio ?? 'No seleccionado';
            document.getElementById('lblFin').textContent     = fechaFin    ?? 'No seleccionado';
            if (fechaInicio && fechaFin) {
                // calcular solo días hábiles (excluir sábados y domingos),
                // excepto usuarios en área 'Planta' que cuentan sábados (excluir solo domingos)
                var includeSat = false;
                try { includeSat = Boolean(@(ViewBag.Vacaciones?.EsPlanta?.ToString().ToLower() ?? "false")); } catch(e) { includeSat = false; }
                const diff = countWorkingDays(new Date(fechaInicio), new Date(fechaFin), includeSat);
                document.getElementById('totalDiasDisplay').value = diff + ' días';
                document.getElementById('inputTotalDias').value   = diff;
                // Comprobar contra días disponibles (proporcionados desde servidor en ViewBag.Vacaciones.DiasDisponibles)
                try {
                    var disponibles = Number(@(ViewBag.Vacaciones?.DiasDisponibles ?? 0));
                    var warningEl = document.getElementById('vacWarning');
                    var submitBtn  = document.getElementById('vacSubmit');
                        var restantesEl = document.getElementById('diasRestantesDisplay');
                        var restantes = disponibles - diff;
                        if (restantesEl) restantesEl.value = (restantes >= 0 ? restantes : 0) + ' días';
                    if (disponibles < diff) {
                        if (warningEl) warningEl.classList.remove('d-none');
                        if (submitBtn) submitBtn.disabled = true;
                    } else {
                        if (warningEl) warningEl.classList.add('d-none');
                        if (submitBtn) submitBtn.disabled = false;
                    }
                } catch(e) { }
            } else {
                document.getElementById('totalDiasDisplay').value = '';
                document.getElementById('inputTotalDias').value   = '';
                    var restantesEl2 = document.getElementById('diasRestantesDisplay');
                    if (restantesEl2) restantesEl2.value = '';
            }
            renderCalendario();
        }

        // Cuenta días hábiles entre dos fechas inclusive. Si includeSaturday=true cuenta sábados (excluye solo domingos).
        function countWorkingDays(startDate, endDate, includeSaturday) {
            if (!startDate || !endDate) return 0;
            var s = new Date(startDate.getFullYear(), startDate.getMonth(), startDate.getDate());
            var e = new Date(endDate.getFullYear(), endDate.getMonth(), endDate.getDate());
            if (e < s) return 0;
            var count = 0;
            for (var d = new Date(s); d <= e; d.setDate(d.getDate() + 1)) {
                var dow = d.getDay(); // 0=Sun,6=Sat
                if (dow === 0) continue; // always skip Sunday
                if (dow === 6 && !includeSaturday) continue; // skip Saturday unless includeSaturday
                count++;
            }
            return count;
        }
    </script>
}