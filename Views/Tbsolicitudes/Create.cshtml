@model Farmacol.Models.Tbsolicitude
@{
    ViewData["Title"] = "Nueva Solicitud";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="text-center mb-5">
                <span class="badge bg-soft-primary text-primary px-3 py-2 rounded-pill mb-3">Módulo de Solicitudes</span>
                <h1 class="display-5 fw-bold text-dark">¿Qué deseas gestionar hoy?</h1>
                <p class="lead text-secondary">Selecciona el tipo de trámite que deseas realizar</p>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <a asp-action="Create" asp-route-tipo="permiso" class="text-decoration-none group-card">
                        <div class="card h-100 shadow-sm border-0 hover-card p-3">
                            <div class="card-body text-center">
                                <div class="icon-circle bg-light-primary text-primary mb-4">
                                    <span class="fs-1">🕐</span>
                                </div>
                                <h4 class="fw-bold text-dark mb-2">Solicitud de Permiso</h4>
                                <p class="text-muted small">Citas médicas, trámites personales o permisos por horas.</p>
                                <div class="mt-3 text-primary fw-semibold small">Continuar <i class="bi bi-arrow-right"></i></div>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-md-6">
                    <a asp-action="Create" asp-route-tipo="vacaciones" class="text-decoration-none group-card">
                        <div class="card h-100 shadow-sm border-0 hover-card p-3">
                            <div class="card-body text-center">
                                <div class="icon-circle bg-light-success text-success mb-4">
                                    <span class="fs-1">🏖️</span>
                                </div>
                                <h4 class="fw-bold text-dark mb-2">Solicitud de Vacaciones</h4>
                                <p class="text-muted small">Descanso anual programado y compensación de días.</p>
                                <div class="mt-3 text-success fw-semibold small">Continuar <i class="bi bi-arrow-right"></i></div>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .hover-card { transition: all 0.3s ease; border: 1px solid transparent !important; }
        .hover-card:hover { transform: translateY(-10px); border-color: #dee2e6 !important; box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important; }
        .icon-circle { width: 80px; height: 80px; display: flex; align-items: center; justify-content: center; border-radius: 50%; margin: 0 auto; }
        .bg-light-primary { background-color: #e7f1ff; }
        .bg-light-success { background-color: #e6fcf5; }
        .badge.bg-soft-primary { background-color: #e7f1ff; color: #0d6efd; }
    </style>
}