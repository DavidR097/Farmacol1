@model IEnumerable<Farmacol.Models.Tbsolicitude>
@{
    ViewData["Title"] = "Mis Solicitudes";

    var enProceso = Model.Count(s => s.Estado == "En proceso");
    var aprobadas = Model.Count(s => s.Estado == "Aprobada");
    var rechazadas = Model.Count(s => s.Estado == "Rechazada");
    var devueltas = Model.Count(s => s.Estado == "Devuelta");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">📁 Mis Solicitudes</h2>
        <small class="text-muted">Historial de todas tus solicitudes</small>
    </div>
    <a asp-action="Create" class="btn btn-primary">➕ Nueva Solicitud</a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <div style="font-size:3.5rem">📭</div>
            <h5 class="mt-3 text-muted">No tienes solicitudes aún</h5>
            <p class="text-muted">Crea tu primera solicitud de permiso o vacaciones.</p>
            <a asp-action="Create" class="btn btn-primary mt-1">➕ Crear solicitud</a>
        </div>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div style="font-size:1.8rem">⏳</div>
                <div class="fw-bold fs-4 text-warning">@enProceso</div>
                <small class="text-muted">En proceso</small>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div style="font-size:1.8rem">✅</div>
                <div class="fw-bold fs-4 text-success">@aprobadas</div>
                <small class="text-muted">Aprobadas</small>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div style="font-size:1.8rem">↩️</div>
                <div class="fw-bold fs-4 text-info">@devueltas</div>
                <small class="text-muted">Devueltas</small>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div style="font-size:1.8rem">❌</div>
                <div class="fw-bold fs-4 text-danger">@rechazadas</div>
                <small class="text-muted">Rechazadas</small>
            </div>
        </div>
    </div>

    <div class="d-flex flex-column gap-3">
        @foreach (var s in Model)
        {
            string badgeClass, icono;
            if (s.Estado == "Aprobada") { badgeClass = "success"; icono = "✅"; }
            else if (s.Estado == "Rechazada") { badgeClass = "danger"; icono = "❌"; }
            else if (s.Estado == "Devuelta") { badgeClass = "info"; icono = "↩️"; }
            else if (s.Estado == "Finalizada") { badgeClass = "secondary"; icono = "🔒"; }
            else { badgeClass = "warning"; icono = "⏳"; }

            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between gap-2 flex-wrap">
                        <div class="d-flex align-items-center gap-3">
                            <span style="font-size:2rem">@icono</span>
                            <div>
                                <div class="fw-bold">
                                    @s.TipoSolicitud
                                    @if (!string.IsNullOrEmpty(s.SubtipoPermiso))
                                    {
                                        <span class="text-muted fw-normal"> — @s.SubtipoPermiso</span>
                                    }
                                </div>
                                <small class="text-muted">
                                    Solicitado el @s.FechaSolicitud?.ToString("dd/MM/yyyy")
                                    @if (s.FechaInicio.HasValue)
                                    {
                                        <span> · @s.FechaInicio.Value.ToString("dd/MM/yyyy")</span>
                                        @if (s.FechaFin.HasValue && s.FechaFin != s.FechaInicio)
                                        {
                                            <span> → @s.FechaFin.Value.ToString("dd/MM/yyyy")</span>
                                        }
                                    }
                                    @if (s.TotalDias.HasValue && s.TotalDias > 0)
                                    {
                                        <span> · @s.TotalDias día(s)</span>
                                    }
                                    @if (s.TotalHoras.HasValue && s.TotalHoras > 0)
                                    {
                                        <span> · @s.TotalHoras hora(s)</span>
                                    }
                                </small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <span class="badge bg-@badgeClass fs-6 px-3 py-2">@s.Estado</span>
                            <a asp-action="Detalle" asp-route-id="@s.IdSolicitud"
                               class="btn btn-sm btn-outline-secondary">👁️ Ver</a>
                            @if (s.Estado == "Devuelta")
                            {
                                <a asp-action="Editar" asp-route-id="@s.IdSolicitud"
                                   class="btn btn-sm btn-warning">✏️ Corregir</a>
                            }
                        </div>
                    </div>

                    @if (s.TotalPasos.HasValue && s.TotalPasos > 0)
                    {
                        <div class="mt-3">
                            <div class="d-flex gap-2 align-items-center flex-wrap">
                                @for (int i = 1; i <= s.TotalPasos; i++)
                                {
                                    string aprobador = i == 1 ? (s.Paso1Aprobador ?? "-")
                                    : i == 2 ? (s.Paso2Aprobador ?? "-")
                                    : (s.Paso3Aprobador ?? "-");
                                    string estadoPaso = i == 1 ? (s.Paso1Estado ?? "")
                                    : i == 2 ? (s.Paso2Estado ?? "")
                                    : (s.Paso3Estado ?? "");
                                    string pClass, pIcon;
                                    if (estadoPaso == "Aprobado") { pClass = "success"; pIcon = "✅"; }
                                    else if (estadoPaso == "Rechazado") { pClass = "danger"; pIcon = "❌"; }
                                    else if (estadoPaso == "Pendiente") { pClass = "warning"; pIcon = "⏳"; }
                                    else { pClass = "secondary"; pIcon = "⬜"; }

                                    <div class="d-flex align-items-center gap-1">
                                        <span class="badge bg-@pClass">@pIcon Paso @i: @aprobador</span>
                                        @if (i < s.TotalPasos)
                                        {
                                            <span class="text-muted">→</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(s.Motivo))
                    {
                        <div class="mt-2">
                            <small class="text-muted">📝 @s.Motivo</small>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
