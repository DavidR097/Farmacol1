@model Farmacol.Models.TbRequisicione
@{
    ViewData["Title"] = $"Requisición - {@Model.NoRequisicion}";
}

<h1>Requisición #@Model.NoRequisicion</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <strong>Información de la Requisición</strong>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Fecha Solicitud</dt>
                    <dd class="col-sm-8">@Model.FechaSolicitud?.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-4">Posición Requerida</dt>
                    <dd class="col-sm-8">@Model.PosicionRequerida</dd>

                    <dt class="col-sm-4">Gerencia Solicitante</dt>
                    <dd class="col-sm-8">@Model.GerenciaSolicitante</dd>

                    <dt class="col-sm-4">Nombre Solicitante</dt>
                    <dd class="col-sm-8">@Model.NombreSolicitante</dd>

                    <dt class="col-sm-4">Cargo Solicitante</dt>
                    <dd class="col-sm-8">@Model.CargoSolicitante</dd>

                    <dt class="col-sm-4">Tipo de Contrato</dt>
                    <dd class="col-sm-8">@Model.TipoContrato</dd>

                    <dt class="col-sm-4">Estado Actual</dt>
                    <dd class="col-sm-8">
                        <span class="badge @(Model.Estado == "Aprobada" ? "bg-success" : "bg-warning") fs-6">
                            @Model.Estado
                        </span>
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">← Volver a la lista</a>
</div>