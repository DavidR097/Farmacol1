@model IEnumerable<Farmacol.Models.TbAuditTrail>
@{
    ViewData["Title"] = "Audit Trail";
    var total = (int)ViewBag.Total;
    var pagina = (int)ViewBag.Pagina;
    var totalPaginas = (int)ViewBag.TotalPaginas;
    var porPagina = (int)ViewBag.PorPagina;
    var modulos = ViewBag.Modulos as List<string> ?? new();
    var acciones = ViewBag.Acciones as List<string> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">🔍 Audit Trail</h2>
        <small class="text-muted">Registro completo de acciones del sistema</small>
    </div>
</div>
<div class="d-flex gap-2 mb-3">
    <!-- Exportar con filtros -->
    <a asp-action="ExportarExcel"
       asp-route-busqueda="@ViewBag.Busqueda"
       asp-route-estado="@ViewBag.Estado"
       class="btn btn-success btn-sm">
        📥 Exportar filtrado
    </a>
    <!-- Exportar todo -->
    <a asp-action="ExportarExcel" asp-route-todo="true"
       class="btn btn-outline-success btn-sm">
        📥 Exportar todo
    </a>
</div>

<!-- Filtros -->
<form method="get" class="mb-4">
    <div class="card border-0 shadow-sm p-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small text-muted mb-1">Usuario</label>
                <input type="text" name="usuario" value="@ViewBag.Usuario"
                       class="form-control" placeholder="Nombre de usuario..." />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Módulo</label>
                <select name="modulo" class="form-select">
                    <option value="">Todos</option>
                    @foreach (var m in modulos)
                    {
                        <option value="@m" selected="@(ViewBag.Modulo == m)">@m</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Acción</label>
                <select name="accion" class="form-select">
                    <option value="">Todas</option>
                    @foreach (var a in acciones)
                    {
                        <option value="@a" selected="@(ViewBag.Accion == a)">@a</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Desde</label>
                <input type="date" name="desde" value="@ViewBag.Desde" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Hasta</label>
                <input type="date" name="hasta" value="@ViewBag.Hasta" class="form-control" />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100">🔍</button>
            </div>
        </div>
        <div class="mt-2">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">✕ Limpiar filtros</a>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay registros con los filtros aplicados.</div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 small">
                <thead class="table-dark">
                    <tr>
                        <th style="width:150px">Fecha</th>
                        <th>Hora</th>
                        <th>Usuario</th>
                        <th>Módulo</th>
                        <th>Acción</th>
                        <th>Descripción</th>
                        <th>ID</th>
                        <th>IP</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        var badgeColor = a.Accion switch
                        {
                                        "Crear" => "success",
                                        "Aprobar" => "success",
                                        "Login" => "info",
                                        "Eliminar" => "danger",
                                        "Rechazar" => "danger",
                                        "Login fallido" => "danger",
                                        "Devolver" => "warning",
                                        "Cancelar" => "warning",
                                        "Editar" => "primary",
                                        "Subir" => "primary",
                                        "Logout" => "secondary",
                            _ => "secondary"
                        };
                        <tr>
                            <td>
                                <small class="font-monospace">@a.Fecha.ToString("dd/MM/yyyy")</small>
                            </td>
                            <td>
                                <small class="font-monospace">@a.Fecha.ToString("HH:mm:ss")</small>
                            </td>
                            <td><strong>@a.Usuario</strong></td>
                            <td>
                                <span class="badge bg-light text-dark border">@a.Modulo</span>
                            </td>
                            <td>
                                <span class="badge bg-@badgeColor">@a.Accion</span>
                            </td>
                            <td class="text-muted">@a.Descripcion</td>
                            <td><small class="font-monospace text-muted">@a.EntidadId</small></td>
                            <td><small class="text-muted">@a.Ip</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación -->
    @if (totalPaginas > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center">
                @for (int i = 1; i <= totalPaginas; i++)
                {
                    <li class="page-item @(i == pagina ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-pagina="@i"
                           asp-route-usuario="@ViewBag.Usuario"
                           asp-route-modulo="@ViewBag.Modulo"
                           asp-route-accion="@ViewBag.Accion"
                           asp-route-desde="@ViewBag.Desde"
                           asp-route-hasta="@ViewBag.Hasta">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
