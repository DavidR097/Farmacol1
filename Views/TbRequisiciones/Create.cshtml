@model Farmacol.Models.TbRequisiciones
@{
    ViewData["Title"] = "Nueva Requisición";
}

<h1>Nueva Requisición de Personal</h1>
<hr />

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="row">
        <div class="col-md-6">
            <div class="form-group mb-3">
                <label class="form-label">No. Requisición</label>
                <input asp-for="NoRequisicion" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label class="form-label">Fecha Solicitud</label>
                <input asp-for="FechaSolicitud" type="date" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label class="form-label">Posición Requerida</label>
                <input asp-for="PosicionRequerida" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label class="form-label">Gerencia Solicitante</label>
                <input asp-for="GerenciaSolicitante" class="form-control" />
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group mb-3">
                <label class="form-label">Nombre Solicitante</label>
                <input asp-for="NombreSolicitante" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label class="form-label">Cargo Solicitante</label>
                <input asp-for="CargoSolicitante" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label class="form-label">Tipo de Contrato</label>
                <input asp-for="TipoContrato" class="form-control" />
            </div>
        </div>
    </div>

    <!-- Sección Conocimientos -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <strong>Conocimientos Requeridos</strong>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="form-check">
                        <input type="checkbox" asp-for="OfimaticaBasica" class="form-check-input" />
                        <label asp-for="OfimaticaBasica" class="form-check-label">Ofimática Básica</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-check">
                        <input type="checkbox" asp-for="OfimaticaIntermedia" class="form-check-input" />
                        <label asp-for="OfimaticaIntermedia" class="form-check-label">Ofimática Intermedia</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-check">
                        <input type="checkbox" asp-for="OfimaticaAvanzada" class="form-check-input" />
                        <label asp-for="OfimaticaAvanzada" class="form-check-label">Ofimática Avanzada</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-check">
                        <input type="checkbox" asp-for="SAP" class="form-check-input" />
                        <label asp-for="SAP" class="form-check-label">SAP</label>
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <label class="form-label fw-bold">Otro ¿Cuál?</label>
                <input asp-for="OtroConocimiento" class="form-control" placeholder="Especifique otros conocimientos" />
            </div>
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Guardar Requisición</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</form>