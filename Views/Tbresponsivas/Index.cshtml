@model Farmacol.Models.TbresponsivaIndexViewModel
@{
    ViewData["Title"] = "Responsivas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">📝 Responsivas</h2>
        <small class="text-muted">Registro de responsivas de equipos tecnológicos</small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">➕ Nueva Responsiva</a>
        <a asp-action="Index" asp-route-mode="equipo" class="btn btn-outline-secondary">Vista por equipo</a>
        <a asp-action="Index" asp-route-mode="cc" class="btn btn-outline-secondary">Vista por CC</a>
    </div>
</div>

<div class="d-flex gap-2 mb-3">
    <!-- Exportar con filtros -->
    <a asp-action="ExportarExcel"
       asp-route-busqueda="@ViewBag.Busqueda"
       asp-route-estado="@ViewBag.Estado"
       class="btn btn-success btn-sm">
        📥 Exportar filtrado
    </a>
    <!-- Exportar todo -->
    <a asp-action="ExportarExcel" asp-route-todo="true"
       class="btn btn-outline-success btn-sm">
        📥 Exportar todo
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Buscador -->
<form method="get" class="mb-4">
    <div class="card border-0 shadow-sm p-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small text-muted mb-1">Búsqueda general</label>
                <input type="text" name="busqueda" value="@ViewBag.Busqueda"
                       class="form-control" placeholder="🔍 Buscar..." />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Cédula</label>
                <input type="text" name="cedula" value="@ViewBag.Cedula"
                       class="form-control" placeholder="CC" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Equipo</label>
                <input type="text" name="equipo" value="@ViewBag.Equipo"
                       class="form-control" placeholder="Laptop, PC..." />
            </div>
            <div class="col-md-1">
                <label class="form-label small text-muted mb-1">Marca</label>
                <input type="text" name="marca" value="@ViewBag.Marca"
                       class="form-control" placeholder="Marca" />
            </div>
            <div class="col-md-1">
                <label class="form-label small text-muted mb-1">Serie</label>
                <input type="text" name="serie" value="@ViewBag.Serie"
                       class="form-control" placeholder="Serie" />
            </div>
            <div class="col-md-1">
                <label class="form-label small text-muted mb-1">Estado</label>
                <select name="estado" class="form-select">
                    <option value="">Todos</option>
                    <option value="Activo" selected="@(ViewBag.Estado == "Activo")">Activo</option>
                    <option value="Inactivo" selected="@(ViewBag.Estado == "Inactivo")">Inactivo</option>
                    <option value="Prestado" selected="@(ViewBag.Estado == "Prestado")">Prestado</option>
                    <option value="Dañado" selected="@(ViewBag.Estado == "Dañado")">Dañado</option>
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
            <div class="col-md-1">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">✕</a>
            </div>
        </div>
    </div>
</form>

@if (Model.Mode == "equipo")
{
    var equipos = Model.Equipos ?? Enumerable.Empty<Farmacol.Models.Tbinventario>();
    if (!equipos.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <div style="font-size:3rem">📭</div>
            <h5 class="mt-3 text-muted">No hay responsivas registradas</h5>
        </div>
    </div>
}
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>CC</th>
                            <th>Equipo</th>
                            <th>Marca</th>
                            <th>Serie</th>
                            <th>Observación</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in equipos)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@item.CC</span></td>
                                <td><strong>@(item.Dispositivo ?? item.Modelo)</strong></td>
                                <td>@item.Marca</td>
                                <td><small class="text-muted font-monospace">@item.Serie</small></td>
                                <td><small class="text-muted">@item.Observación</small></td>
                                <td>
                                    <span class="badge bg-primary">Asignado</span>
                                </td>
                                <td class="text-center">
                                    <a asp-controller="Tbinventarios" asp-action="Details" asp-route-id="@item.IdEquipo"
                                       class="btn btn-sm btn-outline-secondary">👁️</a>
                                    <a asp-controller="Tbinventarios" asp-action="Edit" asp-route-id="@item.IdEquipo"
                                       class="btn btn-sm btn-outline-primary">✏️</a>
                                    <a asp-controller="Tbinventarios" asp-action="Delete" asp-route-id="@item.IdEquipo"
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('¿Eliminar este equipo?')">🗑️</a>
                                    @if (item.CC.HasValue)
                                    {
                                        <a asp-controller="Tbresponsivas" asp-action="Details" asp-route-id="@item.CC"
                                           class="btn btn-sm btn-outline-info ms-1">📁 Responsiva</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="mt-2">
            <small class="text-muted">@equipos.Count() registro(s) encontrado(s)</small>
        </div>
    }
}
else
{
    var grupos = Model.Grupos ?? Enumerable.Empty<Farmacol.Models.TbresponsivaGroup>();
    if (!grupos.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <div style="font-size:3rem">📭</div>
                <h5 class="mt-3 text-muted">No hay responsivas agrupadas por CC</h5>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>CC</th>
                            <th>Nombre</th>
                            <th>Cantidad de equipos</th>
                            <th>Equipo ejemplo</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var g in grupos)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@g.CC</span></td>
                                <td>@g.Nombre ?? "-"</td>
                                <td>@g.Count</td>
                                <td><strong>@g.PrimerEquipo</strong> <small class="text-muted">@g.PrimeraMarca</small></td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@g.CC" class="btn btn-sm btn-outline-info">📁 Ver responsiva</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
