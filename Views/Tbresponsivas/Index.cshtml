@model IEnumerable<Farmacol.Models.Tbresponsiva>
@{
    ViewData["Title"] = "Responsivas";
}

<h1>Responsivas</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Nueva</a>
</p>

<form method="get" class="mb-3">
    <div class="row g-2">
        <div class="col-md-4">
            <input type="text" name="busqueda" value="@ViewBag.Busqueda"
                   class="form-control" placeholder="🔍 Buscar en todo..." />
        </div>
        <div class="col-md-2">
            <input type="text" name="cedula" value="@ViewBag.Cedula"
                   class="form-control" placeholder="CC" />
        </div>
        <div class="col-md-2">
            <input type="text" name="equipo" value="@ViewBag.Equipo"
                   class="form-control" placeholder="Equipo" />
        </div>
        <div class="col-md-2">
            <input type="text" name="marca" value="@ViewBag.Marca"
                   class="form-control" placeholder="Marca" />
        </div>
        <div class="col-md-2">
            <input type="text" name="serie" value="@ViewBag.Serie"
                   class="form-control" placeholder="Serie" />
        </div>
        <div class="col-md-2">
            <input type="text" name="estado" value="@ViewBag.Estado"
                   class="form-control" placeholder="Estado" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-secondary w-100">Filtrar</button>
        </div>
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Limpiar</a>
        </div>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.CC)</th>
            <th>@Html.DisplayNameFor(model => model.Equipo)</th>
            <th>@Html.DisplayNameFor(model => model.Marca)</th>
            <th>@Html.DisplayNameFor(model => model.Serie)</th>
            <th>@Html.DisplayNameFor(model => model.Observación)</th>
            <th>@Html.DisplayNameFor(model => model.Estado)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.CC)</td>
                <td>@Html.DisplayFor(modelItem => item.Equipo)</td>
                <td>@Html.DisplayFor(modelItem => item.Marca)</td>
                <td>@Html.DisplayFor(modelItem => item.Serie)</td>
                <td>@Html.DisplayFor(modelItem => item.Observación)</td>
                <td>@Html.DisplayFor(modelItem => item.Estado)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.CC">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.CC">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.CC">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>