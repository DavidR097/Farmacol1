@model Farmacol.Models.Tbresponsiva
@{
    ViewData["Title"] = "Eliminar responsiva";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0">🗑️ Eliminar responsiva</h4>
    </div>
    <div class="card-body">
        <p>¿Estás seguro que deseas eliminar esta responsiva?</p>
        <dl class="row">
            <dt class="col-sm-3">Equipo</dt>
            <dd class="col-sm-9">@Model.Equipo</dd>
            <dt class="col-sm-3">Marca</dt>
            <dd class="col-sm-9">@Model.Marca</dd>
            <dt class="col-sm-3">Serie</dt>
            <dd class="col-sm-9">@Model.Serie</dd>
            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">@Model.Estado</dd>
            <dt class="col-sm-3">Observación</dt>
            <dd class="col-sm-9">@Model.Observación</dd>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CC" />
            <button type="submit" class="btn btn-danger">Confirmar eliminación</button>
            <a asp-action="Expediente" asp-route-cc="@Model.CC" class="btn btn-secondary ms-2">Cancelar</a>
        </form>
    </div>
</div>
