@model IEnumerable<Farmacol.Models.TbSolicitudTerceros>
@{
    ViewData["Title"] = "Solicitudes de Terceros";
}

<style>
    body { background-color: #f8f9fa; }

    /* Contenedor y Títulos */
    .page-header {
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .table-card {
        background: white;
        border-radius: 16px;
        border: 1px solid #e9ecef;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        padding: 1.5rem;
    }

    /* Estilo de la Tabla */
    .table-custom { font-size: 14px; vertical-align: middle; }
    .table-custom thead th {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6c757d;
        border-top: none;
        border-bottom: 1px solid #f1f5f9;
        padding: 12px 16px;
    }
    .table-custom tbody td {
        padding: 16px;
        color: #374151;
        border-bottom: 1px solid #f1f5f9;
    }

    /* Badges de Estado */
    .status-badge {
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }
    .status-pendiente { background-color: #fef3c7; color: #92400e; }
    .status-aprobado { background-color: #d1fae5; color: #065f46; }
    .status-rechazado { background-color: #fee2e2; color: #991b1b; }
    .status-proceso { background-color: #e0f2fe; color: #075985; }

    /* Botones */
    .btn-create {
        background-color: #111827;
        color: white;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        padding: 8px 16px;
        transition: all 0.2s;
    }
    .btn-create:hover { background-color: #1f2937; color: white; }

    .btn-action {
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-view { color: #4b5563; background: #f3f4f6; border: 1px solid #e5e7eb; }
    .btn-view:hover { background: #e5e7eb; color: #111827; }
    
    .btn-review { color: #ffffff; background: #3b82f6; border: 1px solid #3b82f6; }
    .btn-review:hover { background: #2563eb; color: white; }

    .company-name { font-weight: 600; color: #111827; display: block; }
    .solicitante-name { font-size: 12px; color: #6b7280; }
</style>

<div class="container mt-4 mb-5">
    <!-- Encabezado de Página -->
    <div class="page-header">
        <div>
            <h2 class="fw-bold mb-0" style="color: #111;">Solicitudes de Terceros</h2>
            <p class="text-muted small mb-0">Gestión de accesos y contratistas</p>
        </div>
        <a asp-action="Create" class="btn btn-create shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Nueva Solicitud
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-3 mb-4 d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <div>@TempData["Error"]</div>
        </div>
    }

    <!-- Contenedor de la Tabla -->
    <div class="table-card">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                <p class="mt-3 text-muted">No hay solicitudes registradas actualmente.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-custom mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Empresa / Solicitante</th>
                            <th>Fecha Ingreso</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td class="text-muted">#@s.Id</td>
                                <td>
                                    <span class="company-name">@s.Empresa</span>
                                    <span class="solicitante-name">@s.Solicitante</span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-calendar3 me-2 text-muted"></i>
                                        @(s.FechaIngreso?.ToString("dd MMM, yyyy HH:mm") ?? "-")
                                    </div>
                                </td>
                                <td>
                                    @{
                                        var statusClass = s.Estado?.ToLower() switch {
                                            "aprobado" => "status-aprobado",
                                            "rechazado" => "status-rechazado",
                                            "en proceso" => "status-proceso",
                                            _ => "status-pendiente"
                                        };
                                    }
                                    <span class="status-badge @statusClass">
                                        @(s.Estado ?? "Pendiente")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Details" asp-route-id="@s.Id" class="btn-action btn-view">
                                            <i class="bi bi-eye"></i> Ver
                                        </a>
                                        
                                        @if (User.IsInRole("SST") && (string.IsNullOrEmpty(s.Estado) || s.Estado == "Pendiente" || s.Estado == "En proceso"))
                                        {
                                            <a asp-action="Revisar" asp-route-id="@s.Id" class="btn-action btn-review">
                                                <i class="bi bi-shield-check"></i> Revisar
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>