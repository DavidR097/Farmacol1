@model IEnumerable<Farmacol.Models.TbsoliRechazadum>
@{
    ViewData["Title"] = "Solicitudes Rechazadas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">❌ Solicitudes Rechazadas</h2>
        <small class="text-muted">Historial de solicitudes que no fueron aprobadas</small>
    </div>
</div>

<div class="d-flex gap-2 mb-3">
    <!-- Exportar con filtros -->
    <a asp-action="ExportarExcel"
       asp-route-busqueda="@ViewBag.Busqueda"
       asp-route-estado="@ViewBag.Estado"
       class="btn btn-success btn-sm">
        📥 Exportar filtrado
    </a>
    <!-- Exportar todo -->
    <a asp-action="ExportarExcel" asp-route-todo="true"
       class="btn btn-outline-success btn-sm">
        📥 Exportar todo
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Buscador -->
<form method="get" class="mb-4">
    <div class="card border-0 shadow-sm p-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small text-muted mb-1">Búsqueda general</label>
                <input type="text" name="busqueda" value="@ViewBag.Busqueda"
                       class="form-control" placeholder="🔍 Nombre, tipo..." />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Cédula</label>
                <input type="text" name="cedula" value="@ViewBag.Cedula"
                       class="form-control" placeholder="CC" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Nombre</label>
                <input type="text" name="nombre" value="@ViewBag.Nombre"
                       class="form-control" placeholder="Nombre" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Tipo solicitud</label>
                <input type="text" name="tipoSolicitud" value="@ViewBag.TipoSolicitud"
                       class="form-control" placeholder="Permiso, Vacaciones..." />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
            <div class="col-md-1">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">✕</a>
            </div>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <div style="font-size:3rem">🎉</div>
            <h5 class="mt-3 text-muted">No hay solicitudes rechazadas</h5>
            <p class="text-muted">No se encontraron resultados con los filtros aplicados.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>CC</th>
                        <th>Nombre</th>
                        <th>Tipo Solicitud</th>
                        <th>Motivo rechazo</th>
                        <th>Fecha</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@item.CC</span></td>
                            <td><strong>@item.Nombre</strong></td>
                            <td>
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-2 py-1">
                                    @item.TipoSolicitud
                                </span>
                            </td>
                            <td>
                                <small class="text-muted">@(item.Motivo ?? item.Observaciones ?? "—")</small>
                            </td>
                            <td><small>@item.FechaSolicitud.ToString("dd/MM/yyyy")</small></td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.IdSolicitud"
                                   class="btn btn-sm btn-outline-secondary">👁️ Ver</a>
                                @if (User.IsInRole("Administrador"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.IdSolicitud"
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('¿Eliminar este registro?')">🗑️</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="mt-2">
        <small class="text-muted">@Model.Count() registro(s) encontrado(s)</small>
    </div>
}