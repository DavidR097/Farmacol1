@model IEnumerable<Farmacol.Models.TbExpediente>
@{
    ViewData["Title"] = "Expediente";
    var personal = ViewBag.Personal as Farmacol.Models.Tbpersonal;
    var tipos = ViewBag.Tipos as string[] ?? Array.Empty<string>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-2">← Volver</a>
        <h2 class="mb-0">📂 Expediente de @personal?.NombreColaborador</h2>
        <small class="text-muted">
            CC: @personal?.CC &nbsp;·&nbsp; @personal?.Cargo &nbsp;·&nbsp; @personal?.Area
        </small>
    </div>
    <div>
        <a asp-action="GenerarDocumento" asp-route-cc="@personal?.CC"
           asp-route-plantilla="responsiva"
           class="btn btn-outline-info">
            📄 Generar documento
        </a>
    </div>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Subir nuevo documento -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-light fw-bold">➕ Subir nuevo documento</div>
    <div class="card-body">
        <form asp-action="Subir" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="cc" value="@personal?.CC" />
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Tipo</label>
                    <select name="tipoDocumento" class="form-select">
                        <option value="">Sin categoría</option>
                        @foreach (var t in tipos)
                        {
                            <option>@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Nombre del documento</label>
                    <input type="text" name="nombrePersonalizado" class="form-control"
                           placeholder="Ej: Contrato 2025" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold">Archivo PDF</label>
                    <input type="file" name="archivo" accept=".pdf" class="form-control" required />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">📤 Subir</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Documentos -->
@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <div style="font-size:3rem">📭</div>
            <h5 class="mt-3 text-muted">Sin documentos aún</h5>
            <p class="text-muted">Sube el primer documento para este empleado.</p>
        </div>
    </div>
}
else
{
    <!-- Agrupar por tipo -->
    @foreach (var grupo in Model.GroupBy(d => d.TipoDocumento ?? "Sin categoría").OrderBy(g => g.Key))
    {
        <div class="mb-3">
            <h6 class="text-muted text-uppercase small fw-bold mb-2">
                📂 @grupo.Key <span class="badge bg-light text-dark border">@grupo.Count()</span>
            </h6>
            <div class="card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Nombre</th>
                                <th>Subido por</th>
                                <th>Fecha</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in grupo.OrderByDescending(d => d.FechaSubida))
                            {
                                <tr>
                                    <td>
                                        <span style="font-size:1.2rem">📄</span>
                                        <strong class="ms-1">@doc.NombreArchivo</strong>
                                    </td>
                                    <td><small class="text-muted">@doc.SubidoPor</small></td>
                                    <td><small>@doc.FechaSubida.ToString("dd/MM/yyyy HH:mm")</small></td>
                                    <td class="text-center">
                                        <a asp-action="Ver" asp-route-id="@doc.Id"
                                           target="_blank"
                                           class="btn btn-sm btn-outline-primary">👁️ Ver</a>
                                        <form asp-action="Eliminar" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@doc.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('¿Eliminar este documento?')">
                                                🗑️
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}
