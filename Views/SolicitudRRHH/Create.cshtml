@{
    ViewData["Title"] = "Solicitar documento RRHH";
    var personal = ViewBag.Personal as Farmacol.Models.Tbpersonal;
    var tiposDocumento = ViewBag.TiposDocumento as string[] ?? Array.Empty<string>();
}

<div class="mb-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">← Inicio</a>
</div>

<h2>📄 Solicitar documento a Capital Humano</h2>
<p class="text-muted">Tu solicitud llegará directamente al Gerente de Capital Humano.</p>
<hr />

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form asp-action="Create" method="post" style="max-width:650px" id="formSolicitud">
    @Html.AntiForgeryToken()
    <div class="card border-0 shadow-sm">
        <div class="card-header fw-semibold text-white" style="background:#198754">
            📄 Nueva solicitud de documento
        </div>
        <div class="card-body">
            <div class="row g-3">

                <div class="col-12">
                    <div class="alert alert-light border small py-2 mb-0">
                        <strong>Solicitante:</strong> @personal?.NombreColaborador
                        <span class="text-muted"> — @personal?.Cargo · @personal?.Area</span>
                        <span class="badge bg-secondary ms-2">CC: @personal?.CC</span>
                    </div>
                </div>

                <div class="col-12">
                    <label class="form-label fw-bold">Documento solicitado <span class="text-danger">*</span></label>
                    <div class="row g-2 mt-1">
                        @foreach (var tipo in tiposDocumento)
                        {
                            <div class="col-md-6">
                                <label class="d-flex align-items-center gap-2 p-3 border rounded option-card" style="cursor:pointer; transition: all .2s ease;">
                                    <input type="radio" name="documentoSolicitado" value="@tipo" required class="form-check-input mt-0" onclick="mostrarCampos(this.value)" />
                                    <span class="small fw-medium">
                                        @(tipo switch {
                                            "Certificado Laboral" => "📋 Certificado laboral",
                                            "Paz y salvo" => "✅ Paz y salvo",
                                            "Retiro de Cesantias" => "💲 Retiro de Cesantías",
                                            _ => tipo
                                        })
                                    </span>
                                </label>
                            </div>
                        }
                    </div>
                </div>

                <div id="seccionDinamica" class="col-12 d-none">
                    <div class="p-3 border rounded bg-light">
                        
                        <!-- Campos para Certificado Laboral -->
                        <div id="campos-Certificado" class="extra-fields d-none">
                            <h6 class="fw-bold mb-2 small text-success">Opciones de Certificado</h6>                        
                            <div class="form-check form-switch small">
                                <input class="form-check-input" type="checkbox" name="IncluirSueldo" id="swSueldo" value="true" />
                                <input type="hidden" name="IncluirSueldo" value="false" />
                                <label class="form-check-label" for="swSueldo">Incluir salario mensual</label>
                            </div>
                            <div class="form-check form-switch small">
                                <input class="form-check-input" type="checkbox" name="IncluirFunciones" id="swFunciones" value="true" />
                                <input type="hidden" name="IncluirFunciones" value="false" />
                                <label class="form-check-label" for="swFunciones">Incluir funciones detalladas</label>
                            </div>
                            <input type="text" name="DirigidoA" class="form-control form-control-sm mt-2" placeholder="¿A quién se dirige el documento? (Ej: Banco X, Embajada...)" />
                        </div>

                        <!-- Campos para Retiro de Cesantías -->
                        <div id="campos-Cesantias" class="extra-fields d-none">
                            <h6 class="fw-bold mb-2 small text-success">Detalles de Cesantías</h6>
                            <select name="MotivoCesantias" class="form-select form-select-sm mb-2">
                                <option value="">Seleccione el motivo del retiro...</option>
                                <option value="Vivienda">Compra / Mejora de Vivienda</option>
                                <option value="Educación">Educación Superior / Diplomados</option>
                                <option value="Otros">Otros motivos legales</option>
                            </select>
                            <input type="number" name="MontoCesantias" class="form-control form-control-sm mb-2" placeholder="Monto aproximado a solicitar" step="0.01" />
                            <small class="text-muted" style="font-size:11px">Monto sugerido (opcional).</small>
                        </div>

                        <!-- Campos para Paz y Salvo (nuevo bloque) -->
                        <div id="campos-PazSalvo" class="extra-fields d-none">
                            <h6 class="fw-bold mb-2 small text-success">Información de Retiro</h6>
                            <input type="date" name="FechaRetiro" class="form-control form-control-sm" title="Fecha de último día laborado" />
                            <small class="text-muted" style="font-size:11px">Indique su último día laborado para la liquidación.</small>
                        </div>

                    </div>
                </div>

                <div class="col-12">
                    <label class="form-label fw-bold">Observaciones adicionales</label>
                    <textarea name="motivo" class="form-control" rows="2"
                              placeholder="Escribe aquí cualquier detalle adicional que debamos saber..."
                              maxlength="500"></textarea>
                </div>

            </div>
        </div>
        <div class="card-footer d-flex gap-2 bg-white border-top-0 pb-3">
            <button type="submit" class="btn btn-success fw-bold px-4">
                📤 Enviar solicitud
            </button>
            <a asp-controller="Tbsolicitudes" asp-action="MisSolicitudes" class="btn btn-outline-secondary">
                Ver mis solicitudes
            </a>
        </div>
    </div>
</form>

<style>
    .option-card:hover {
        background-color: #f0fdf4;
        border-color: #198754 !important;
    }
    .option-card:has(input:checked) {
        background-color: #e8f5e9;
        border-color: #198754 !important;
        box-shadow: 0 0 0 1px #198754;
    }
    input[type="radio"]:checked {
        background-color: #198754;
        border-color: #198754;
    }
</style>

<script>
    function mostrarCampos(tipo) {
        const seccionDinamica = document.getElementById('seccionDinamica');
        seccionDinamica.classList.remove('d-none');

        document.querySelectorAll('.extra-fields').forEach(el => el.classList.add('d-none'));

        if (tipo === "Certificado Laboral") {
            document.getElementById('campos-Certificado').classList.remove('d-none');
        } 
        else if (tipo === "Retiro de Cesantias") {
            document.getElementById('campos-Cesantias').classList.remove('d-none');
        }
        else if (tipo === "Paz y salvo") {
            document.getElementById('campos-PazSalvo').classList.remove('d-none');
        }
    }
</script>