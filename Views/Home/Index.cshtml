@{
    ViewData["Title"] = "Home";
    var anuncios = ViewBag.Anuncios as List<Farmacol.Models.TbAnuncio> ?? new List<Farmacol.Models.TbAnuncio>();
}

    <div class="row align-items-start">
        <div class="col-lg-3 d-none d-lg-block">
            <div class="d-flex flex-column gap-3">
                <div id="lateralLeft" class="card shadow-sm" style="aspect-ratio:555/774; overflow:hidden;">
                    <div class="d-flex align-items-center justify-content-center h-100 text-muted">Sin anuncio lateral</div>
                </div>
                @* Los anuncios laterales con dimensiones válidas se determinan en el servidor y están en ViewBag.LateralAnuncios *@
            </div>
        </div>

        <div class="col-lg-6 mb-3">
            @* Centro vacío: solo laterales con acordeón *@
            <div class="d-flex h-100 align-items-center justify-content-center">
                <div></div>
            </div>
        </div>
        <div class="col-lg-3 d-none d-lg-block">
            <div class="d-flex flex-column gap-3">
                <div id="lateralRight" class="card shadow-sm" style="aspect-ratio:555/774; overflow:hidden;">
                    <div class="d-flex align-items-center justify-content-center h-100 text-muted">Sin anuncio lateral</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            @* Eliminados los iconos circulares según solicitud del usuario *@
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            try {
                // LateralAnuncios proviene del servidor y ya están filtrados por tamaño
                var lateralData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.LateralAnuncios ?? new List<Farmacol.Models.TbAnuncio>()));
                var allAnuncios = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Anuncios ?? new List<Farmacol.Models.TbAnuncio>()));
                if (!lateralData || lateralData.length === 0) return;
                console.debug('Lateral data:', lateralData);
                var imgs = lateralData.map(function (a) {
                    var src = a.Imagen || a.imagen || a.ImagenUrl || a.imagenUrl || a.url || a.Url || '';
                    var titulo = a.Titulo || a.titulo || '';
                    var mensaje = a.Mensaje || a.mensaje || '';
                    return { src: src, titulo: titulo, mensaje: mensaje };
                }).filter(function (x) { return x.src && x.src.length > 0; });

                var left = document.getElementById('lateralLeft');
                var right = document.getElementById('lateralRight');
                if (!left || !right) return;

                // Preload images
                var preloaded = [];
                var loaded = 0;
                imgs.forEach(function (it, idx) {
                    var im = new Image();
                    im.onload = function () { loaded++; preloaded[idx] = im; };
                    im.onerror = function () { loaded++; preloaded[idx] = null; };
                    im.src = it.src;
                });

                function startRotation() {
                    var valid = imgs.filter(function(_, i) { return preloaded[i]; });
                    var indices = preloaded.map(function(p, idx) { return p ? idx : -1; }).filter(function(i){ return i >= 0; });
                    if (indices.length === 0) return;

                    var n = indices.length;
                    var pos = 0;
                    function show() {
                        var leftIdx = indices[pos % n];
                        var rightIdx = indices[(pos + 1) % n];
                        var a = imgs[leftIdx];
                        var b = imgs[rightIdx];
                        left.innerHTML = '<img src="' + a.src + '" style="width:100%;height:100%;object-fit:cover;transition: transform .6s;" alt="' + (a.titulo || '') + '">';
                        right.innerHTML = '<img src="' + b.src + '" style="width:100%;height:100%;object-fit:cover;transition: transform .6s;" alt="' + (b.titulo || '') + '">';
                        var leftImg = left.querySelector('img');
                        var rightImg = right.querySelector('img');
                        if (leftImg && rightImg) {
                            leftImg.style.transform = 'scale(1.02)'; rightImg.style.transform = 'scale(0.98)';
                            setTimeout(function () { leftImg.style.transform = 'scale(0.98)'; rightImg.style.transform = 'scale(1.02)'; }, 2500);
                        }
                        pos = (pos + 1) % n;
                    }
                    show();
                    setInterval(show, 5000);
                }

                // Wait up to 1s for preload, then start
                var waitStart = Date.now();
                var waiter = setInterval(function () {
                    if (loaded >= imgs.length || Date.now() - waitStart > 1000) {
                        clearInterval(waiter);
                        startRotation();
                    }
                }, 50);
            } catch (e) { console.warn(e); }
        });
    </script>
}
